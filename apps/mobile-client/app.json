{
  "expo": {
    "name": "Bellu",
    "slug": "bellu-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "glamapp",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#C4918E"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.glamapp.client",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#C4918E"
      },
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyACtVOd9e3hazjcTbkQT6V5VYoZ2dmt-9c"
        }
      },
      "package": "com.glamapp.client",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      [
        "expo-router",
        {
          "root": "./app"
        }
      ],
      "expo-localization",
      "expo-splash-screen",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow $(PRODUCT_NAME) to use your location to find nearby professionals."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#C4918E",
          "sounds": []
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false,
        "root": "./app"
      },
      "eas": {
        "projectId": "b06ec0f9-63d5-498b-932d-b02d82aedb30"
      }
    }
  }
}
