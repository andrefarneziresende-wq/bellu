{
  "expo": {
    "name": "Bellu",
    "slug": "glamapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "glamapp",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAF7F5"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.glamapp.client"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FAF7F5"
      },
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyACtVOd9e3hazjcTbkQT6V5VYoZ2dmt-9c"
        }
      },
      "package": "com.glamapp.client"
    },
    "plugins": [
      ["expo-router", { "root": "./app" }],
      "expo-localization",
      "expo-splash-screen",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow $(PRODUCT_NAME) to use your location to find nearby professionals."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#C4918E",
          "sounds": []
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
