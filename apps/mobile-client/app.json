{
  "expo": {
    "name": "GlamApp",
    "slug": "glamapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "glamapp",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#FAF7F5"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.glamapp.client"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FAF7F5"
      },
      "package": "com.glamapp.client"
    },
    "plugins": [
      "expo-router",
      "expo-localization"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
