// ============================================================
// Beauty Marketplace — Prisma Schema
// ============================================================

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  // extensions = [postgis]  // Enable when spatial queries are needed
}

// ============================================================
// Country
// ============================================================

model Country {
  id             String   @id @default(uuid())
  code           String   @unique @db.VarChar(2) // BR, ES
  name           String   @db.VarChar(100)
  currency       String   @db.VarChar(3) // BRL, EUR
  currencySymbol String   @db.VarChar(5) // R$, €
  timezone       String   @db.VarChar(50) // America/Sao_Paulo, Europe/Madrid
  locale         String   @db.VarChar(10) // pt-BR, es-ES
  phonePrefix    String   @db.VarChar(5) // +55, +34
  active         Boolean  @default(true)
  createdAt      DateTime @default(now()) @map("created_at")

  users           User[]
  professionals   Professional[]
  adminUsers      AdminUser[]
  banners         Banner[]
  platformConfigs PlatformConfig[]

  @@map("countries")
}

// ============================================================
// User (Consumer)
// ============================================================

model User {
  id           String   @id @default(uuid())
  name         String   @db.VarChar(100)
  email        String?  @unique @db.VarChar(255)
  phone        String?  @unique @db.VarChar(20)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  avatar       String?  @db.VarChar(500)
  latitude     Float?
  longitude    Float?
  countryId    String   @map("country_id")
  locale       String   @default("pt-BR") @db.VarChar(10)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  country       Country        @relation(fields: [countryId], references: [id])
  professional  Professional?
  bookings      Booking[]
  reviews       Review[]
  favorites     Favorite[]
  sentMessages  ChatMessage[]  @relation("MessageSender")
  receivedMessages ChatMessage[] @relation("MessageReceiver")
  refreshTokens RefreshToken[]

  @@index([countryId])
  @@index([email])
  @@index([phone])
  @@map("users")
}

// ============================================================
// Refresh Token
// ============================================================

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique @db.VarChar(500)
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("refresh_tokens")
}

// ============================================================
// Professional
// ============================================================

model Professional {
  id           String             @id @default(uuid())
  userId       String             @unique @map("user_id")
  businessName String             @map("business_name") @db.VarChar(150)
  description  String?            @db.Text
  address      String             @db.VarChar(500)
  latitude     Float
  longitude    Float
  coverPhoto   String?            @map("cover_photo") @db.VarChar(500)
  avatarPhoto  String?            @map("avatar_photo") @db.VarChar(500)
  rating       Float              @default(0)
  totalReviews Int                @default(0) @map("total_reviews")
  verified     Boolean            @default(false)
  active       Boolean            @default(true)
  status       ProfessionalStatus @default(PENDING)
  countryId    String             @map("country_id")
  taxId        String             @map("tax_id") @db.VarChar(20)
  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @updatedAt @map("updated_at")

  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  country       Country         @relation(fields: [countryId], references: [id])
  services      Service[]
  portfolioItems PortfolioItem[]
  workingHours  WorkingHours[]
  bookings      Booking[]
  reviews       Review[]
  favoritedBy   Favorite[]

  @@index([countryId])
  @@index([status])
  @@index([latitude, longitude])
  @@index([rating])
  @@map("professionals")
}

enum ProfessionalStatus {
  PENDING
  APPROVED
  SUSPENDED
  BANNED
}

// ============================================================
// Category
// ============================================================

model Category {
  id    String @id @default(uuid())
  slug  String @unique @db.VarChar(50)
  icon  String @db.VarChar(50)
  order Int    @default(0)

  translations CategoryTranslation[]
  services     Service[]

  @@map("categories")
}

model CategoryTranslation {
  id         String @id @default(uuid())
  categoryId String @map("category_id")
  locale     String @db.VarChar(10) // pt-BR, es-ES, en
  name       String @db.VarChar(100)

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, locale])
  @@map("category_translations")
}

// ============================================================
// Service
// ============================================================

model Service {
  id              String @id @default(uuid())
  professionalId  String @map("professional_id")
  categoryId      String @map("category_id")
  name            String @db.VarChar(150)
  description     String? @db.Text
  price           Decimal @db.Decimal(10, 2)
  currency        String  @db.VarChar(3) // BRL, EUR
  durationMinutes Int     @map("duration_minutes")
  active          Boolean @default(true)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  professional   Professional    @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  category       Category        @relation(fields: [categoryId], references: [id])
  portfolioItems PortfolioItem[]
  bookings       Booking[]

  @@index([professionalId])
  @@index([categoryId])
  @@index([price])
  @@map("services")
}

// ============================================================
// Portfolio Item
// ============================================================

model PortfolioItem {
  id             String   @id @default(uuid())
  professionalId String   @map("professional_id")
  serviceId      String?  @map("service_id")
  beforePhoto    String?  @map("before_photo") @db.VarChar(500)
  afterPhoto     String   @map("after_photo") @db.VarChar(500)
  description    String?  @db.Text
  createdAt      DateTime @default(now()) @map("created_at")

  professional Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  service      Service?     @relation(fields: [serviceId], references: [id], onDelete: SetNull)

  @@index([professionalId])
  @@map("portfolio_items")
}

// ============================================================
// Working Hours
// ============================================================

model WorkingHours {
  id             String  @id @default(uuid())
  professionalId String  @map("professional_id")
  dayOfWeek      Int     @map("day_of_week") // 0=Sunday, 6=Saturday
  startTime      String  @map("start_time") @db.VarChar(5) // HH:mm
  endTime        String  @map("end_time") @db.VarChar(5)   // HH:mm
  isOff          Boolean @default(false) @map("is_off")

  professional Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@unique([professionalId, dayOfWeek])
  @@map("working_hours")
}

// ============================================================
// Booking
// ============================================================

model Booking {
  id             String        @id @default(uuid())
  userId         String        @map("user_id")
  professionalId String        @map("professional_id")
  serviceId      String        @map("service_id")
  date           DateTime      @db.Date
  startTime      String        @map("start_time") @db.VarChar(5) // HH:mm
  endTime        String        @map("end_time") @db.VarChar(5)   // HH:mm
  status         BookingStatus @default(PENDING)
  totalPrice     Decimal       @map("total_price") @db.Decimal(10, 2)
  currency       String        @db.VarChar(3)
  paymentStatus  PaymentStatus @default(PENDING) @map("payment_status")
  cancelledAt    DateTime?     @map("cancelled_at")
  completedAt    DateTime?     @map("completed_at")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  user         User         @relation(fields: [userId], references: [id])
  professional Professional @relation(fields: [professionalId], references: [id])
  service      Service      @relation(fields: [serviceId], references: [id])
  review       Review?
  payment      Payment?
  chatMessages ChatMessage[]

  @@index([userId])
  @@index([professionalId])
  @@index([date])
  @@index([status])
  @@map("bookings")
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum PaymentStatus {
  PENDING
  PAID
  REFUNDED
  FAILED
}

// ============================================================
// Review
// ============================================================

model Review {
  id             String   @id @default(uuid())
  bookingId      String   @unique @map("booking_id")
  userId         String   @map("user_id")
  professionalId String   @map("professional_id")
  rating         Int      // 1-5
  comment        String?  @db.Text
  photoUrl       String?  @map("photo_url") @db.VarChar(500)
  createdAt      DateTime @default(now()) @map("created_at")

  booking      Booking      @relation(fields: [bookingId], references: [id])
  user         User         @relation(fields: [userId], references: [id])
  professional Professional @relation(fields: [professionalId], references: [id])

  @@index([professionalId])
  @@index([userId])
  @@index([rating])
  @@map("reviews")
}

// ============================================================
// Payment
// ============================================================

model Payment {
  id         String   @id @default(uuid())
  bookingId  String   @unique @map("booking_id")
  amount     Decimal  @db.Decimal(10, 2)
  currency   String   @db.VarChar(3)
  method     String   @db.VarChar(20) // pix, card, boleto, sepa, bizum
  status     PaymentStatus @default(PENDING)
  gateway    String   @db.VarChar(20) // mercadopago, stripe
  externalId String?  @map("external_id") @db.VarChar(255)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  booking Booking @relation(fields: [bookingId], references: [id])

  @@index([externalId])
  @@map("payments")
}

// ============================================================
// Chat Message
// ============================================================

model ChatMessage {
  id         String    @id @default(uuid())
  bookingId  String    @map("booking_id")
  senderId   String    @map("sender_id")
  receiverId String    @map("receiver_id")
  message    String    @db.Text
  readAt     DateTime? @map("read_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  booking  Booking @relation(fields: [bookingId], references: [id])
  sender   User    @relation("MessageSender", fields: [senderId], references: [id])
  receiver User    @relation("MessageReceiver", fields: [receiverId], references: [id])

  @@index([bookingId])
  @@index([senderId])
  @@index([receiverId])
  @@map("chat_messages")
}

// ============================================================
// Favorite
// ============================================================

model Favorite {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  professionalId String   @map("professional_id")
  createdAt      DateTime @default(now()) @map("created_at")

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  professional Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@unique([userId, professionalId])
  @@map("favorites")
}

// ============================================================
// Admin User
// ============================================================

model AdminUser {
  id           String    @id @default(uuid())
  name         String    @db.VarChar(100)
  email        String    @unique @db.VarChar(255)
  passwordHash String    @map("password_hash") @db.VarChar(255)
  role         AdminRole @default(MODERATOR)
  countryId    String?   @map("country_id")
  active       Boolean   @default(true)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  country Country? @relation(fields: [countryId], references: [id])

  @@map("admin_users")
}

enum AdminRole {
  SUPERADMIN
  ADMIN
  MODERATOR
}

// ============================================================
// Banner
// ============================================================

model Banner {
  id        String    @id @default(uuid())
  imageUrl  String    @map("image_url") @db.VarChar(500)
  targetUrl String?   @map("target_url") @db.VarChar(500)
  active    Boolean   @default(true)
  order     Int       @default(0)
  startDate DateTime? @map("start_date")
  endDate   DateTime? @map("end_date")
  countryId String?   @map("country_id")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  country Country? @relation(fields: [countryId], references: [id])

  @@index([countryId])
  @@index([active])
  @@map("banners")
}

// ============================================================
// Platform Config
// ============================================================

model PlatformConfig {
  id        String  @id @default(uuid())
  key       String  @db.VarChar(100)
  value     String  @db.Text
  countryId String? @map("country_id")

  country Country? @relation(fields: [countryId], references: [id])

  @@unique([key, countryId])
  @@map("platform_configs")
}
