// ============================================================
// Beauty Marketplace — Prisma Schema
// ============================================================

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  // extensions = [postgis]  // Enable when spatial queries are needed
}

// ============================================================
// Country
// ============================================================

model Country {
  id             String   @id @default(uuid())
  code           String   @unique @db.VarChar(2) // BR, ES
  name           String   @db.VarChar(100)
  currency       String   @db.VarChar(3) // BRL, EUR
  currencySymbol String   @db.VarChar(5) // R$, €
  timezone       String   @db.VarChar(50) // America/Sao_Paulo, Europe/Madrid
  locale         String   @db.VarChar(10) // pt-BR, es-ES
  phonePrefix    String   @db.VarChar(5) // +55, +34
  active         Boolean  @default(true)
  createdAt      DateTime @default(now()) @map("created_at")

  users           User[]
  professionals   Professional[]
  adminUsers      AdminUser[]
  banners         Banner[]
  platformConfigs PlatformConfig[]

  @@map("countries")
}

// ============================================================
// User (Consumer)
// ============================================================

model User {
  id            String   @id @default(uuid())
  name          String   @db.VarChar(100)
  email         String?  @unique @db.VarChar(255)
  phone         String?  @unique @db.VarChar(20)
  passwordHash  String?  @map("password_hash") @db.VarChar(255)
  avatar        String?  @db.VarChar(500)
  latitude      Float?
  longitude     Float?
  countryId     String   @map("country_id")
  locale        String   @default("pt-BR") @db.VarChar(10)
  active        Boolean  @default(true)
  authProvider  String?  @map("auth_provider") @db.VarChar(20) // google, apple, email
  authProviderId String? @map("auth_provider_id") @db.VarChar(255)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  country       Country        @relation(fields: [countryId], references: [id])
  professional  Professional?
  memberProfile ProfessionalMember? // staff member link
  bookings      Booking[]
  reviews       Review[]
  favorites     Favorite[]
  sentMessages  ChatMessage[]  @relation("MessageSender")
  receivedMessages ChatMessage[] @relation("MessageReceiver")
  clientConversations  Conversation[]        @relation("ClientConversations")
  conversationMessages ConversationMessage[] @relation("ConversationMessageSender")
  refreshTokens RefreshToken[]
  clientPackages ClientPackage[]
  uploadedPhotos BookingPhoto[] @relation("BookingPhotoUploader")
  pushTokens     PushToken[]
  notifications  Notification[]

  @@index([countryId])
  @@index([email])
  @@index([phone])
  @@map("users")
}

// ============================================================
// Refresh Token
// ============================================================

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique @db.VarChar(500)
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("refresh_tokens")
}

// ============================================================
// Password Reset Token
// ============================================================

model PasswordResetToken {
  id        String   @id @default(uuid())
  email     String   @db.VarChar(255)
  code      String   @db.VarChar(6) // 6-digit code
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([email, code])
  @@map("password_reset_tokens")
}

// ============================================================
// Legal Document (Terms of Use, Privacy Policy, etc.)
// ============================================================

model LegalDocument {
  id        String   @id @default(uuid())
  type      String   @db.VarChar(50) // terms_of_use, privacy_policy
  locale    String   @db.VarChar(10)
  title     String   @db.VarChar(200)
  content   String   @db.Text
  version   String   @db.VarChar(20)
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([type, locale, version])
  @@map("legal_documents")
}

// ============================================================
// Professional
// ============================================================

model Professional {
  id           String             @id @default(uuid())
  userId       String             @unique @map("user_id")
  businessName String             @map("business_name") @db.VarChar(150)
  description  String?            @db.Text
  address      String             @db.VarChar(500)
  latitude     Float
  longitude    Float
  coverPhoto   String?            @map("cover_photo") @db.VarChar(500)
  avatarPhoto  String?            @map("avatar_photo") @db.VarChar(500)
  rating       Float              @default(0)
  totalReviews Int                @default(0) @map("total_reviews")
  verified     Boolean            @default(false)
  active       Boolean            @default(true)
  status       ProfessionalStatus @default(PENDING)
  countryId    String             @map("country_id")
  taxId        String             @map("tax_id") @db.VarChar(20)
  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @updatedAt @map("updated_at")

  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  country       Country         @relation(fields: [countryId], references: [id])
  services      Service[]
  servicePackages ServicePackage[]
  portfolioItems PortfolioItem[]
  workingHours  WorkingHours[]
  bookings      Booking[]
  reviews       Review[]
  favoritedBy   Favorite[]
  members       ProfessionalMember[]
  staffRoles    StaffRole[]
  expenses       Expense[]
  promotions     Promotion[]
  clientPackages ClientPackage[]
  conversations  Conversation[]

  @@index([countryId])
  @@index([status])
  @@index([latitude, longitude])
  @@index([rating])
  @@map("professionals")
}

enum ProfessionalStatus {
  PENDING
  APPROVED
  SUSPENDED
  BANNED
}

// ============================================================
// Category
// ============================================================

model Category {
  id    String @id @default(uuid())
  slug  String @unique @db.VarChar(50)
  icon  String @db.VarChar(50)
  order Int    @default(0)

  translations     CategoryTranslation[]
  services         Service[]
  serviceTemplates ServiceTemplate[]

  @@map("categories")
}

model CategoryTranslation {
  id         String @id @default(uuid())
  categoryId String @map("category_id")
  locale     String @db.VarChar(10) // pt-BR, es-ES, en
  name       String @db.VarChar(100)

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, locale])
  @@map("category_translations")
}

// ============================================================
// Service Template (Admin catalog)
// ============================================================

model ServiceTemplate {
  id         String  @id @default(uuid())
  categoryId String  @map("category_id")
  name       String  @db.VarChar(150)
  active     Boolean @default(true)
  order      Int     @default(0)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  category   Category  @relation(fields: [categoryId], references: [id])
  services   Service[]

  @@index([categoryId])
  @@map("service_templates")
}

// ============================================================
// Service (Professional's offering based on template)
// ============================================================

model Service {
  id                String  @id @default(uuid())
  professionalId    String  @map("professional_id")
  categoryId        String  @map("category_id")
  serviceTemplateId String? @map("service_template_id")
  name              String  @db.VarChar(150)
  description       String? @db.Text
  price             Decimal @db.Decimal(10, 2)
  currency          String  @db.VarChar(3) // BRL, EUR
  durationMinutes   Int     @map("duration_minutes")
  active            Boolean @default(true)
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  professional      Professional     @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  category          Category         @relation(fields: [categoryId], references: [id])
  serviceTemplate   ServiceTemplate? @relation(fields: [serviceTemplateId], references: [id])
  portfolioItems    PortfolioItem[]
  bookings          Booking[]
  servicePackages   ServicePackage[]
  promotionServices PromotionService[]
  order             Int              @default(0)

  @@index([professionalId])
  @@index([categoryId])
  @@index([serviceTemplateId])
  @@index([price])
  @@map("services")
}

// ============================================================
// Portfolio Item
// ============================================================

model PortfolioItem {
  id             String   @id @default(uuid())
  professionalId String   @map("professional_id")
  serviceId      String?  @map("service_id")
  beforePhoto    String?  @map("before_photo") @db.VarChar(500)
  afterPhoto     String   @map("after_photo") @db.VarChar(500)
  description    String?  @db.Text
  createdAt      DateTime @default(now()) @map("created_at")

  professional Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  service      Service?     @relation(fields: [serviceId], references: [id], onDelete: SetNull)

  @@index([professionalId])
  @@map("portfolio_items")
}

// ============================================================
// Working Hours
// ============================================================

model WorkingHours {
  id             String  @id @default(uuid())
  professionalId String  @map("professional_id")
  memberId       String? @map("member_id")
  dayOfWeek      Int     @map("day_of_week") // 0=Sunday, 6=Saturday
  startTime      String  @map("start_time") @db.VarChar(5) // HH:mm
  endTime        String  @map("end_time") @db.VarChar(5)   // HH:mm
  isOff          Boolean @default(false) @map("is_off")

  professional Professional       @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  member       ProfessionalMember? @relation(fields: [memberId], references: [id], onDelete: SetNull)

  @@unique([professionalId, dayOfWeek])
  @@map("working_hours")
}

// ============================================================
// Booking
// ============================================================

model Booking {
  id             String        @id @default(uuid())
  userId         String?       @map("user_id")
  professionalId String        @map("professional_id")
  memberId       String?       @map("member_id")
  serviceId      String        @map("service_id")
  date           DateTime      @db.Date
  startTime      String        @map("start_time") @db.VarChar(5) // HH:mm
  endTime        String        @map("end_time") @db.VarChar(5)   // HH:mm
  status         BookingStatus @default(PENDING)
  totalPrice     Decimal       @map("total_price") @db.Decimal(10, 2)
  currency       String        @db.VarChar(3)
  paymentStatus  PaymentStatus @default(PENDING) @map("payment_status")
  source         BookingSource @default(APP)
  clientName     String?       @map("client_name") @db.VarChar(100)
  clientPhone    String?       @map("client_phone") @db.VarChar(20)
  notes            String?       @db.Text
  clientPackageId  String?       @map("client_package_id")
  sessionNumber    Int?          @map("session_number")
  cancelledAt      DateTime?     @map("cancelled_at")
  completedAt      DateTime?     @map("completed_at")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  user           User?               @relation(fields: [userId], references: [id])
  professional   Professional        @relation(fields: [professionalId], references: [id])
  member         ProfessionalMember? @relation(fields: [memberId], references: [id], onDelete: SetNull)
  service        Service             @relation(fields: [serviceId], references: [id])
  clientPackage  ClientPackage?      @relation(fields: [clientPackageId], references: [id])
  review         Review?
  payment        Payment?
  chatMessages   ChatMessage[]
  photos         BookingPhoto[]

  @@index([userId])
  @@index([professionalId])
  @@index([memberId])
  @@index([date])
  @@index([status])
  @@index([clientPackageId])
  @@map("bookings")
}

enum BookingSource {
  APP
  MANUAL
  WALKIN
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum PaymentStatus {
  PENDING
  PAID
  REFUNDED
  FAILED
}

// ============================================================
// Review
// ============================================================

model Review {
  id             String    @id @default(uuid())
  bookingId      String    @unique @map("booking_id")
  userId         String    @map("user_id")
  professionalId String    @map("professional_id")
  rating         Int       // 1-5
  comment        String?   @db.Text
  photoUrl       String?   @map("photo_url") @db.VarChar(500)
  responseText   String?   @map("response_text") @db.Text
  respondedAt    DateTime? @map("responded_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  booking      Booking      @relation(fields: [bookingId], references: [id])
  user         User         @relation(fields: [userId], references: [id])
  professional Professional @relation(fields: [professionalId], references: [id])

  @@index([professionalId])
  @@index([userId])
  @@index([rating])
  @@map("reviews")
}

// ============================================================
// Payment
// ============================================================

model Payment {
  id         String   @id @default(uuid())
  bookingId  String   @unique @map("booking_id")
  amount     Decimal  @db.Decimal(10, 2)
  currency   String   @db.VarChar(3)
  method     String   @db.VarChar(20) // pix, card, boleto, sepa, bizum
  status     PaymentStatus @default(PENDING)
  gateway    String   @db.VarChar(20) // mercadopago, stripe
  externalId String?  @map("external_id") @db.VarChar(255)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  booking Booking @relation(fields: [bookingId], references: [id])

  @@index([externalId])
  @@map("payments")
}

// ============================================================
// Chat Message
// ============================================================

model ChatMessage {
  id         String    @id @default(uuid())
  bookingId  String    @map("booking_id")
  senderId   String    @map("sender_id")
  receiverId String    @map("receiver_id")
  message    String    @db.Text
  readAt     DateTime? @map("read_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  booking  Booking @relation(fields: [bookingId], references: [id])
  sender   User    @relation("MessageSender", fields: [senderId], references: [id])
  receiver User    @relation("MessageReceiver", fields: [receiverId], references: [id])

  @@index([bookingId])
  @@index([senderId])
  @@index([receiverId])
  @@map("chat_messages")
}

// ============================================================
// Favorite
// ============================================================

model Favorite {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  professionalId String   @map("professional_id")
  createdAt      DateTime @default(now()) @map("created_at")

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  professional Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@unique([userId, professionalId])
  @@map("favorites")
}

// ============================================================
// Admin Staff Role
// ============================================================

model AdminStaffRole {
  id          String   @id @default(uuid())
  name        String   @db.VarChar(50)
  description String?  @db.VarChar(255)
  permissions String   @db.Text // JSON array
  isDefault   Boolean  @default(false) @map("is_default")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  admins AdminUser[]

  @@unique([name])
  @@map("admin_staff_roles")
}

// ============================================================
// Admin User
// ============================================================

model AdminUser {
  id           String    @id @default(uuid())
  name         String    @db.VarChar(100)
  email        String    @unique @db.VarChar(255)
  passwordHash String    @map("password_hash") @db.VarChar(255)
  roleId       String?   @map("role_id")
  countryId    String?   @map("country_id")
  active       Boolean   @default(true)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  staffRole AdminStaffRole? @relation(fields: [roleId], references: [id])
  country   Country?        @relation(fields: [countryId], references: [id])

  @@map("admin_users")
}

// ============================================================
// Banner
// ============================================================

model Banner {
  id        String    @id @default(uuid())
  imageUrl  String    @map("image_url") @db.VarChar(500)
  targetUrl String?   @map("target_url") @db.VarChar(500)
  active    Boolean   @default(true)
  order     Int       @default(0)
  startDate DateTime? @map("start_date")
  endDate   DateTime? @map("end_date")
  countryId String?   @map("country_id")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  country Country? @relation(fields: [countryId], references: [id])

  @@index([countryId])
  @@index([active])
  @@map("banners")
}

// ============================================================
// Platform Config
// ============================================================

model PlatformConfig {
  id        String  @id @default(uuid())
  key       String  @db.VarChar(100)
  value     String  @db.Text
  countryId String? @map("country_id")

  country Country? @relation(fields: [countryId], references: [id])

  @@unique([key, countryId])
  @@map("platform_configs")
}

// ============================================================
// Staff Role (custom roles with granular permissions)
// ============================================================

model StaffRole {
  id             String  @id @default(uuid())
  professionalId String  @map("professional_id")
  name           String  @db.VarChar(50) // e.g. "Gerente", "Recepcionista", "Cabeleireiro"
  description    String? @db.VarChar(255)
  permissions    String  @db.Text // JSON array of permission strings
  isDefault      Boolean @default(false) @map("is_default") // built-in roles can't be deleted
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  professional Professional       @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  members      ProfessionalMember[]

  @@unique([professionalId, name])
  @@index([professionalId])
  @@map("staff_roles")
}

// ============================================================
// Professional Member (staff/team)
// ============================================================

model ProfessionalMember {
  id               String  @id @default(uuid())
  professionalId   String  @map("professional_id")
  userId           String? @unique @map("user_id") // linked user account (for login)
  roleId           String? @map("role_id")
  name             String  @db.VarChar(100)
  email            String? @db.VarChar(255)
  phone            String? @db.VarChar(20)
  avatar           String? @db.VarChar(500)
  role             String  @default("staff") @db.VarChar(20) // owner, staff (legacy label)
  specialties      String? @db.Text // JSON array of specialties
  commissionPercent Decimal? @map("commission_percent") @db.Decimal(5, 2)
  active           Boolean @default(true)
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  professional Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  staffRole    StaffRole?   @relation(fields: [roleId], references: [id], onDelete: SetNull)
  bookings     Booking[]
  workingHours WorkingHours[]

  @@index([professionalId])
  @@index([userId])
  @@index([roleId])
  @@map("professional_members")
}

// ============================================================
// Service Package
// ============================================================

model ServicePackage {
  id             String   @id @default(uuid())
  professionalId String   @map("professional_id")
  serviceId      String   @map("service_id")
  name           String   @db.VarChar(150)
  description    String?  @db.Text
  sessionsTotal  Int      @map("sessions_total")
  intervalDays   Int?     @map("interval_days") // recommended days between sessions
  priceTotal     Decimal  @map("price_total") @db.Decimal(10, 2)
  currency       String   @db.VarChar(3)
  active         Boolean  @default(true)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  professional   Professional   @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  service        Service        @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  clientPackages ClientPackage[]

  @@index([professionalId])
  @@map("service_packages")
}

// ============================================================
// Client Package (purchased treatment package instance)
// ============================================================

model ClientPackage {
  id                String              @id @default(uuid())
  userId            String              @map("user_id")
  servicePackageId  String              @map("service_package_id")
  professionalId    String              @map("professional_id")
  totalSessions     Int                 @map("total_sessions")
  sessionsUsed      Int                 @default(0) @map("sessions_used")
  status            ClientPackageStatus @default(ACTIVE)
  expiryDate        DateTime?           @map("expiry_date") @db.Date
  notes             String?             @db.Text
  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @updatedAt @map("updated_at")

  user             User            @relation(fields: [userId], references: [id])
  servicePackage   ServicePackage  @relation(fields: [servicePackageId], references: [id])
  professional     Professional    @relation(fields: [professionalId], references: [id])
  bookings         Booking[]

  @@index([userId])
  @@index([professionalId])
  @@index([status])
  @@map("client_packages")
}

enum ClientPackageStatus {
  ACTIVE
  COMPLETED
  EXPIRED
  CANCELLED
}

// ============================================================
// Booking Photo (evolution tracking per appointment)
// ============================================================

model BookingPhoto {
  id           String   @id @default(uuid())
  bookingId    String   @map("booking_id")
  imageUrl     String   @map("image_url") @db.VarChar(500)
  description  String?  @db.Text
  uploadedById String   @map("uploaded_by_id")
  createdAt    DateTime @default(now()) @map("created_at")

  booking    Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  uploadedBy User    @relation("BookingPhotoUploader", fields: [uploadedById], references: [id])

  @@index([bookingId])
  @@map("booking_photos")
}

// ============================================================
// Expense
// ============================================================

model Expense {
  id             String   @id @default(uuid())
  professionalId String   @map("professional_id")
  description    String   @db.VarChar(255)
  amount         Decimal  @db.Decimal(10, 2)
  currency       String   @db.VarChar(3)
  category       String   @db.VarChar(50) // rent, product, equipment, other
  date           DateTime @db.Date
  recurring      Boolean  @default(false)
  createdAt      DateTime @default(now()) @map("created_at")

  professional Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@index([professionalId])
  @@index([date])
  @@map("expenses")
}

// ============================================================
// Promotion
// ============================================================

model Promotion {
  id             String   @id @default(uuid())
  professionalId String   @map("professional_id")
  name           String   @db.VarChar(150)
  discountType   String   @map("discount_type") @db.VarChar(10) // percent, fixed
  discountValue  Decimal  @map("discount_value") @db.Decimal(10, 2)
  startDate      DateTime @map("start_date")
  endDate        DateTime @map("end_date")
  active         Boolean  @default(true)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  professional Professional   @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  services     PromotionService[]

  @@index([professionalId])
  @@index([active])
  @@map("promotions")
}

model PromotionService {
  id          String @id @default(uuid())
  promotionId String @map("promotion_id")
  serviceId   String @map("service_id")

  promotion Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  service   Service   @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([promotionId, serviceId])
  @@map("promotion_services")
}

// ============================================================
// Push Token (FCM device tokens for push notifications)
// ============================================================

model PushToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @db.VarChar(500)
  platform  String   @db.VarChar(10) // ios, android, web
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, token])
  @@index([userId])
  @@index([token])
  @@map("push_tokens")
}

// ============================================================
// Notification (in-app notification log)
// ============================================================

model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  title     String   @db.VarChar(200)
  body      String   @db.Text
  type      String   @db.VarChar(50) // booking_created, booking_confirmed, booking_cancelled, booking_reminder, review_received, promotion, admin_broadcast, pro_message, chat_message
  data      String?  @db.Text // JSON payload for deep-linking
  read      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@index([read])
  @@map("notifications")
}

// ============================================================
// Scheduled Notification (admin broadcast with delay)
// ============================================================

model ScheduledNotification {
  id          String   @id @default(uuid())
  title       String   @db.VarChar(200)
  body        String   @db.Text // Supports {{name}} tag
  target      String   @db.VarChar(20) @default("client") // client | professional | all
  countryId   String?  @map("country_id")
  scheduledAt DateTime @map("scheduled_at")
  sentAt      DateTime? @map("sent_at")
  status      String   @db.VarChar(20) @default("pending") // pending | sent | cancelled
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([status, scheduledAt])
  @@map("scheduled_notifications")
}

// ============================================================
// Contact Form (website)
// ============================================================

model ContactForm {
  id        String   @id @default(uuid())
  name      String   @db.VarChar(100)
  email     String   @db.VarChar(255)
  subject   String   @db.VarChar(255)
  message   String   @db.Text
  source    String   @default("website") @db.VarChar(20)
  resolved  Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("contact_forms")
}

// ============================================================
// Conversation (direct messaging between client and professional)
// ============================================================

model Conversation {
  id              String    @id @default(uuid())
  clientId        String    @map("client_id")
  professionalId  String    @map("professional_id")
  lastMessageAt   DateTime? @map("last_message_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  client       User                  @relation("ClientConversations", fields: [clientId], references: [id])
  professional Professional          @relation(fields: [professionalId], references: [id])
  messages     ConversationMessage[]

  @@unique([clientId, professionalId])
  @@index([clientId])
  @@index([professionalId])
  @@map("conversations")
}

model ConversationMessage {
  id             String    @id @default(uuid())
  conversationId String    @map("conversation_id")
  senderId       String    @map("sender_id")
  message        String?   @db.Text
  imageUrl       String?   @map("image_url") @db.VarChar(500)
  readAt         DateTime? @map("read_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id])
  sender       User         @relation("ConversationMessageSender", fields: [senderId], references: [id])

  @@index([conversationId, createdAt])
  @@index([senderId])
  @@map("conversation_messages")
}
