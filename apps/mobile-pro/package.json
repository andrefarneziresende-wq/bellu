{
  "name": "@beauty/mobile-pro",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "postinstall": "node -e \"try{const p=require('path').resolve(__dirname,'../../node_modules/expo-modules-core/package.json');const f=require('fs');const j=JSON.parse(f.readFileSync(p,'utf8'));if(j.main.endsWith('.ts')){j.main='build/index.js';f.writeFileSync(p,JSON.stringify(j,null,2));console.log('Patched expo-modules-core main field')}}catch(e){}\""
  },
  "dependencies": {
    "@beauty/shared-i18n": "*",
    "@beauty/shared-types": "*",
    "@beauty/shared-utils": "*",
    "@react-native-picker/picker": "2.9.0",
    "@react-navigation/native": "^7.0.0",
    "@tanstack/react-query": "^5.60.0",
    "expo": "~52.0.0",
    "expo-apple-authentication": "~7.1.3",
    "expo-auth-session": "~6.0.3",
    "expo-constants": "~17.0.8",
    "expo-device": "~7.0.3",
    "expo-image": "~2.0.0",
    "expo-image-picker": "~16.0.6",
    "expo-localization": "~16.0.0",
    "expo-modules-core": "^1.12.26",
    "expo-notifications": "^0.29.14",
    "expo-router": "~4.0.0",
    "expo-status-bar": "~2.0.0",
    "expo-updates": "~0.27.5",
    "expo-web-browser": "~14.0.2",
    "i18next": "^24.0.0",
    "react": "18.3.1",
    "react-i18next": "^15.1.0",
    "react-native": "0.76.3",
    "react-native-reanimated": "~3.16.0",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.1.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/react": "~18.3.0",
    "typescript": "~5.3.0"
  }
}
